    .copy-wrap { padding: 0 18px 14px; background: #fff; }
    button { background: #1e1e1e; color: #aaa; border: none; border-radius: 4px; font-size: 11px; font-weight: 700; letter-spacing: .07em; padding: 5px 14px; cursor: pointer; }
